# Copy this file and rename it to .env, then fill in your values. Do it in directory ai/
# copy .env.example .env    # Windows
# cp .env.example .env      # Mac/Linux
# download the already trained model from: git clone https://huggingface.co/bozhikovb/receipt_classifier
# and insert it into ai/categorization/models/

# ── OCR API ────────────────────────────────────────
OCR_API_URL=https://api.ocr.space/parse/image
OCR_API_KEY=

# ── Model  ────────────────────────────────────────
MODEL_PATH=categorization/models/receipt_classifier

# ── Tesseract fallback ─────────────────────────────
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: /usr/bin/tesseract
TESSERACT_CMD=
